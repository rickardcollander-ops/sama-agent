# SAMA 2.0 Environment Variables
# Copy this to .env.local and fill in your values

# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google APIs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_CLIENT_ID=your-google-ads-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-google-ads-refresh-token
GOOGLE_ADS_CUSTOMER_ID=your-google-ads-customer-id

# SEO APIs
SEMRUSH_API_KEY=your-semrush-api-key
AHREFS_API_KEY=your-ahrefs-api-key
VALUESERP_API_KEY=your-valueserp-api-key  # Get at valueserp.com - for SERP analysis

# Social Media
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Supabase (primary database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Vector Store
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=sama-memory

# Redis (Event Bus & Cache)
REDIS_URL=redis://localhost:6379/0

# Temporal.io
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=sama

# Monitoring
SENTRY_DSN=your-sentry-dsn
DATADOG_API_KEY=your-datadog-api-key

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
SUCCESSIFIER_DOMAIN=successifier.com
SUCCESSIFIER_CMS_API_URL=https://successifier.com/api
SUCCESSIFIER_CMS_API_KEY=your-cms-api-key

# LinkedIn Agent Integration
LINKEDIN_AGENT_EVENT_BUS_ENABLED=true
LINKEDIN_AGENT_API_URL=http://localhost:3003/api

# Human-in-the-Loop
AUTO_PUBLISH_BLOG_POSTS=false
AUTO_PUBLISH_LANDING_PAGES=false
AUTO_PUBLISH_SOCIAL_POSTS=true
AUTO_RESPOND_REVIEWS_POSITIVE=true
AUTO_RESPOND_REVIEWS_NEGATIVE=false
BUDGET_CHANGE_APPROVAL_THRESHOLD=0.30

# ── Security & scalability hardening (added 2026-05) ─────────────────────────

# CORS
# Comma-separated allowlist. Wildcards (https://*.example.com) are expanded
# into a regex automatically. Falls back to settings.CORS_ORIGINS if unset.
CORS_ALLOWED_ORIGINS=https://app.successifier.com,https://sama.successifier.com,https://*.vercel.app
# Set to 1 ONLY in dev/staging — opens CORS to *.
CORS_DEV_PERMISSIVE=0

# Tenant middleware
# Reject protected requests that have no JWT (highest-strength tenant gate).
REQUIRE_AUTHENTICATED_TENANT=1
# Require X-Sama-Account-Id (or JWT) on protected paths.
REQUIRE_TENANT_HEADERS=1
# Comma-separated tenant_ids still allowed to use the legacy X-Tenant-ID header.
LEGACY_TENANT_HEADERS_ALLOW=
# Cross-check X-Sama-Site-Id against account_sites (one extra DB call).
STRICT_SITE_VALIDATION=0

# Secrets vault (encrypts secret-shaped fields in user_settings)
# 32-byte master key, base64-encoded. Generate with:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
MASTER_KMS_KEY=
# Once backfill is complete, flip to 1 to ignore plaintext column on read.
READ_ENCRYPTED_ONLY=0

# Rate limiter
# memory | redis. Memory is per-process; redis works across replicas.
RATE_LIMITER_BACKEND=memory

# LLM guardrails
LLM_CONCURRENCY=30
LLM_PER_TENANT_CONCURRENCY=6
MAX_INPUT_TOKENS=8000
MAX_OUTPUT_TOKENS_DEFAULT=4096
MAX_OUTPUT_TOKENS_HARD_CAP=8192
LLM_TIMEOUT_SECONDS=45

# Request limits middleware
MAX_BODY_BYTES=2000000
REQUEST_TIMEOUT_S=120

# Outbound HTTP guard (SSRF + body cap)
OUTBOUND_HTTP_TIMEOUT_S=10
OUTBOUND_HTTP_MAX_BYTES=5242880

# Worker process
# Set to 1 in worker.py only — web replicas leave unset to avoid duplicated jobs.
RUN_BACKGROUND_JOBS=0
WORKER_LOCK_TTL_S=300

# Agent run streaming
AGENT_RUN_POLL_MS=1000
AGENT_RUN_STREAM_MAX_S=900

# Logging
# json | text. JSON is what Datadog/Sentry ingest cleanly.
LOG_FORMAT=text

# Sentry
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_ENVIRONMENT=production

# Stripe (per-site subscriptions + 3-day trial)
# Reuses an existing Stripe account — just create one Product + Price
# ($169 / month recurring) and paste the price_id into STRIPE_PRICE_SITE.
# Webhook secret comes from the endpoint you create at
# https://dashboard.stripe.com/webhooks pointing at
# <backend>/api/subscriptions/webhook with the events:
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_failed
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# The single recurring price billed per site (quantity == number of sites).
STRIPE_PRICE_SITE=price_xxx
SITE_PRICE_USD=169
# Where Stripe returns the user after Checkout. Defaults to
# DASHBOARD_BASE_URL/c/settings/billing and /c/pricing.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
# Trial length in days. Matches the 3-day trial copy on the pricing page.
TRIAL_DAYS=3

# Admin email — same value as the dashboard's lib/admin.ts ADMIN_EMAIL.
# Required for /api/subscriptions/admin/* endpoints.
ADMIN_EMAIL=rc@successifier.com

# PDF render service (used by the dashboard's Apollo telemarketing flow)
# Comma-separated allowlist of hosts the headless-Chromium renderer is
# allowed to fetch — defaults to *.successifier.com + *.vercel.app.
PDF_RENDER_ALLOWED_HOSTS=
# Shared secret for the dashboard ↔ agent PDF call. When set, /api/pdf/render
# requires the X-Sama-Internal-Token header to match.
SAMA_INTERNAL_TOKEN=
